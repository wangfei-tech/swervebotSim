<?xml version="1.0"?>
<robot name="swerve_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.679" />
    <xacro:property name="base_width" value="0.550" />
    <xacro:property name="base_height" value="0.15" />
    <xacro:property name="wheel_radius" value="0.08" />
    <xacro:property name="wheel_length" value="0.044" />
    <xacro:property name="caster_length" value="0.075" />
    <xacro:property name="caster_width" value="0.075" />
    <xacro:property name="caster_height" value="0.1" />

    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <geometry>
                 <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="20.0" x="${base_length}" y="${base_width}" z="${base_height}"
                           o_xyz="0 0 ${base_height}" o_rpy="0 0 0" />
    </link>

    <xacro:macro name="caster_link" params="prefix">
        <link name="${prefix}_caster_link">
            <visual>
                <geometry>
                    <box size="${caster_length} ${caster_width} ${caster_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <material name="black" />
            </visual>
            <collision>
                <geometry>
                    <box size="${caster_length} ${caster_width} ${caster_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
            </collision>
            <xacro:box_inertia m="10.0" x="${caster_length}" y="${caster_width}" z="${caster_height}"
                            o_xyz="0 0 ${caster_height}" o_rpy="0 0 0" />
        </link>
    </xacro:macro>

    <xacro:caster_link prefix="front_right" />
    <xacro:caster_link prefix="front_left" />
    <xacro:caster_link prefix="back_right" />
    <xacro:caster_link prefix="back_left" />

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="orange" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
            </collision>
            <xacro:cylinder_inertia m="10.0" r="${wheel_radius}" l="${wheel_length}"
                                    o_xyz="0 0 0" o_rpy="${pi / 2.0} 0 0" />
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix="front_right" />
    <xacro:wheel_link prefix="front_left" />
    <xacro:wheel_link prefix="back_right" />
    <xacro:wheel_link prefix="back_left" />


    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 ${base_height / 2 + wheel_radius * 2 + (caster_height / 2 - wheel_radius / 2)}" rpy="0 0 0"/>
    </joint>

    <joint name="base_frontleft_caster_joint" type="continuous">
        <parent link="base_link" />
        <child link="front_left_caster_link" />
        <origin xyz="${base_length / 2 - caster_length / 2} ${base_width / 2 - caster_width / 2} ${- base_height / 2 - caster_height / 2}" rpy="0 0 0"/>
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_frontright_caster_joint" type="continuous">
        <parent link="base_link" />
        <child link="front_right_caster_link" />
        <origin xyz="${base_length / 2 - caster_length / 2} ${-base_width / 2 + caster_width / 2} ${- base_height / 2 - caster_height / 2}" rpy="0 0 0"/>
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_backleft_caster_joint" type="continuous">
        <parent link="base_link" />
        <child link="back_left_caster_link" />
        <origin xyz="${-base_length / 2 + caster_length / 2} ${base_width / 2 - caster_width / 2} ${- base_height / 2 - caster_height / 2}" rpy="0 0 0"/>
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_backright_caster_joint" type="continuous">
        <parent link="base_link" />
        <child link="back_right_caster_link" />
        <origin xyz="${-base_length / 2 + caster_length / 2} ${-base_width / 2 + caster_width / 2} ${- base_height / 2 - caster_height / 2}" rpy="0 0 0"/>
        <axis xyz="0 0 1" />
    </joint>

    <joint name="frontleft_caster_wheel_joint" type="continuous">
        <parent link="front_left_caster_link" />
        <child link="front_left_wheel_link" />
        <origin xyz="0 0 ${-wheel_radius / 2}" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>

    <joint name="frontright_caster_wheel_joint" type="continuous">
        <parent link="front_right_caster_link" />
        <child link="front_right_wheel_link" />
        <origin xyz="0 0 ${-wheel_radius / 2}" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>

    <joint name="backleft_caster_wheel_joint" type="continuous">
        <parent link="back_left_caster_link" />
        <child link="back_left_wheel_link" />
        <origin xyz="0 0 ${-wheel_radius / 2}" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>

    <joint name="backright_caster_wheel_joint" type="continuous">
        <parent link="back_right_caster_link" />
        <child link="back_right_wheel_link" />
        <origin xyz="0 0 ${-wheel_radius / 2}" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>


</robot>